#usda 1.0

class "_class_CharGroup"
{
    over "RefChar"
    {
        over "RefTask"
        {
        }
    }
}

class "_class_Task"
{
}

def "RefCharGroup"   (
    inherits = </_class_CharGroup>
)
{
    def "RefChar"
    {
        over "RefTask" (
            inherits = </_class_Task>
        )
        {
        }
    }
}

